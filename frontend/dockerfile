# frontend/Dockerfile
# ─────────────────────────────────────────────────────────────────
# Stage 1 — deps
#   Installs node_modules once and caches them.
#   Rebuilt only when package.json / package-lock.json change.
# ─────────────────────────────────────────────────────────────────
FROM node:22-alpine AS deps

WORKDIR /app

COPY package.json package-lock.json* ./

# --mount=type=cache keeps the npm cache between builds
RUN --mount=type=cache,target=/root/.npm \
    npm ci --prefer-offline

# ─────────────────────────────────────────────────────────────────
# Stage 2 — dev
#   Vite dev server with HMR.
#   Used by: docker compose (default target)
# ─────────────────────────────────────────────────────────────────
FROM node:22-alpine AS dev

WORKDIR /app

# Non-root user (node already exists in the official image)
RUN chown node:node /app
USER node

COPY --from=deps --chown=node:node /app/node_modules ./node_modules
COPY --chown=node:node . .

EXPOSE 5173

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
  CMD wget -qO- http://localhost:5173 || exit 1

CMD ["npm", "run", "dev"]

# ─────────────────────────────────────────────────────────────────
# Stage 3 — builder
#   Compiles static assets.
#   Runs only during the prod build.
# ─────────────────────────────────────────────────────────────────
FROM deps AS builder

WORKDIR /app

COPY . .

# Inject the API URL at build time (Vite replaces it at compile)
ARG VITE_API_URL
ENV VITE_API_URL=${VITE_API_URL}

RUN --mount=type=cache,target=/root/.npm \
    npm run build

# ─────────────────────────────────────────────────────────────────
# Stage 4 — prod
#   Minimal nginx image — no Node.js at all.
#   Used by: docker compose -f compose.prod.yaml
# ─────────────────────────────────────────────────────────────────
FROM nginx:1.27-alpine AS prod

# Remove default nginx placeholder
RUN rm -rf /usr/share/nginx/html/*

# Copy compiled assets from builder
COPY --from=builder /app/dist /usr/share/nginx/html

# SPA routing + gzip + security headers
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Run nginx as non-root
RUN chown -R nginx:nginx /usr/share/nginx/html \
    && chown -R nginx:nginx /var/cache/nginx \
    && touch /var/run/nginx.pid \
    && chown nginx:nginx /var/run/nginx.pid

USER nginx

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD wget -qO- http://localhost:3000 || exit 1
