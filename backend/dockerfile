# backend/Dockerfile
# ─────────────────────────────────────────────────────────────────
# Stage 1 — base
#   FrankenPHP (Caddy + PHP in one binary) on PHP 8.3.
#   Installs system packages and PHP extensions shared by all stages.
# ─────────────────────────────────────────────────────────────────
FROM dunglas/frankenphp:1-php8.3-bookworm AS base

WORKDIR /app

# System dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
        acl \
        unzip \
        git \
        curl \
    && rm -rf /var/lib/apt/lists/*

# PHP extensions (install-php-extensions is bundled in FrankenPHP images)
RUN install-php-extensions \
    intl \
    zip \
    opcache \
    pdo_mysql \
    apcu \
    @composer-2

# Shared PHP baseline config
COPY docker/php/app.ini $PHP_INI_DIR/conf.d/app.ini

# ─────────────────────────────────────────────────────────────────
# Stage 2 — dev
#   Adds Xdebug, uses php.ini-development, mounts sources via volume.
#   Used by: docker compose (default target)
# ─────────────────────────────────────────────────────────────────
FROM base AS dev

ENV APP_ENV=dev

# Development php.ini (display_errors = On, etc.)
RUN mv "$PHP_INI_DIR/php.ini-development" "$PHP_INI_DIR/php.ini"

# Xdebug for step debugging (VS Code / PhpStorm)
RUN install-php-extensions xdebug
COPY docker/php/app.dev.ini $PHP_INI_DIR/conf.d/app.dev.ini

# Install Composer deps (no lockfile assumed → install; update to composer install if lockfile added)
# Sources are mounted at runtime via the compose volume, so we only
# need vendor/ baked in for the initial boot.
COPY composer.json composer.lock* ./
RUN --mount=type=cache,target=/root/.composer \
    composer install --no-scripts --no-autoloader --prefer-dist

COPY . .

RUN composer dump-autoload --optimize

COPY docker/entrypoint.sh /usr/local/bin/docker-entrypoint
RUN chmod +x /usr/local/bin/docker-entrypoint

EXPOSE 80 443 443/udp

HEALTHCHECK --interval=15s --timeout=5s --start-period=30s --retries=3 \
  CMD curl -sf http://localhost:80 || exit 1

ENTRYPOINT ["docker-entrypoint"]
CMD ["frankenphp", "run", "--config", "/etc/caddy/Caddyfile"]

# ─────────────────────────────────────────────────────────────────
# Stage 3 — prod
#   No Xdebug, OPcache tuned, non-root user, no dev dependencies.
#   Used by: docker compose -f compose.prod.yaml
# ─────────────────────────────────────────────────────────────────
FROM base AS prod

ENV APP_ENV=prod
ENV APP_DEBUG=0

# Production php.ini (display_errors = Off, OPcache aggressive)
RUN mv "$PHP_INI_DIR/php.ini-production" "$PHP_INI_DIR/php.ini"
COPY docker/php/app.prod.ini $PHP_INI_DIR/conf.d/app.prod.ini

# Install production Composer deps only
COPY composer.json composer.lock* ./
RUN --mount=type=cache,target=/root/.composer \
    composer install \
        --no-dev \
        --no-scripts \
        --no-autoloader \
        --prefer-dist \
        --optimize-autoloader

COPY . .

RUN composer dump-autoload --optimize --no-dev \
    && php bin/console cache:warmup --env=prod

# Non-root: grant frankenphp permission to bind to ports < 1024 without root
RUN useradd -r -u 1001 -g www-data appuser \
    && setcap CAP_NET_BIND_SERVICE=+eip /usr/local/bin/frankenphp \
    && chown -R appuser:www-data /app

USER appuser

COPY docker/entrypoint.sh /usr/local/bin/docker-entrypoint
RUN chmod +x /usr/local/bin/docker-entrypoint

EXPOSE 80 443 443/udp

HEALTHCHECK --interval=30s --timeout=5s --start-period=40s --retries=3 \
  CMD curl -sf http://localhost:80 || exit 1
# TODO: switch to /api/health once endpoint is added:
# CMD curl -sf http://localhost:80/api/health || exit 1

ENTRYPOINT ["docker-entrypoint"]
CMD ["frankenphp", "run", "--config", "/etc/caddy/Caddyfile"]
